{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Embroidery Catalogue",
  "version": "0.1.0",
  "identifier": "com.embroidery-catalogue.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Embroidery Catalogue",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: https://cdn.tailwindcss.com; img-src 'self' data: blob: tauri: asset:; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
